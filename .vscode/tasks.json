{
  "version": "2.0.0",
  "presentation": {
    "clear": true,
    "panel": "dedicated",
    "showReuseMessage": false
  },
  "options": {
    "cwd": "${workspaceFolder}"
  },
  "problemMatcher": [],
  "tasks": [
    {
      "label": "Install: Ruby Gem packages",
      "detail": "Install packages for website",
      "type": "shell",
      "command": "bundle install --jobs 4 && bundle clean --force",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "BUNDLE_GEMFILE": "${workspaceFolder}/Gemfile",
          "BUNDLE_PATH": "${workspaceFolder}/vendor/bundle"
        }
      }
    },
    {
      "label": "Update: Ruby Gem packages",
      "detail": "Update Ruby gem packages (conservative update and cleanup)",
      "type": "shell",
      "command": "bundle lock --add-platform x86_64-linux x64-mingw-ucrt && bundle update --conservative && bundle clean --force",
      "dependsOn": "Install: Ruby Gem packages",
      "dependsOrder": "sequence",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "BUNDLE_GEMFILE": "${workspaceFolder}/Gemfile",
          "BUNDLE_PATH": "${workspaceFolder}/vendor/bundle"
        }
      }
    },
    {
      "label": "Lint: Markdown",
      "detail": "Check for markdown file linting issues",
      "type": "shell",
      "command": "npx markdownlint-cli2"
    },
    {
      "label": "Lint: Markdown (fix)",
      "detail": "Auto-fix markdown file linting issues (where possible).",
      "type": "shell",
      "command": "npx markdownlint-cli2 --fix"
    },
    {
      "label": "Run: Website (LiveReload)",
      "detail": "Start local Jekyll dev server with LiveReload (background)",
      "type": "shell",
      "command": "bundle exec jekyll serve --livereload --open-url",
      "isBackground": true,
      "dependsOn": "Install: Ruby Gem packages",
      "dependsOrder": "sequence",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "BUNDLE_GEMFILE": "${workspaceFolder}/Gemfile",
          "BUNDLE_PATH": "${workspaceFolder}/vendor/bundle"
        }
      }
    }
  ]
}
